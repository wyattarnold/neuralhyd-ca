# Zarr v3 cubes — every file inside a *.zarr directory (metadata + binary chunks).
# Chunk files have no extension, so the rule must match .zarr stores anywhere
# in the repo and recurse beneath them.
**/*.zarr/** filter=lfs diff=lfs merge=lfs -text
